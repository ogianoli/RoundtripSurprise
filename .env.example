# Public app config. This is safe to expose to Expo.
# Local physical phone testing:
# EXPO_PUBLIC_SOCIAL_RESEARCH_ENDPOINT=http://YOUR_MAC_IP:8787/research/place
#
# Production/TestFlight:
EXPO_PUBLIC_SOCIAL_RESEARCH_ENDPOINT=https://roundtrip-research-backend.onrender.com/research/place

# Optional direct YouTube mode for early tests.
# Prefer using the backend instead, because backend keys are not exposed in the app bundle.
EXPO_PUBLIC_YOUTUBE_API_KEY=
